
#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:Windows
/config:
/profile:Reach
/compress:True

#-------------------------------- References --------------------------------#

/reference:..\..\Framework\bin\Debug\net4.8\ZZZ.Framework.dll
/reference:..\..\Monogame\bin\Debug\net4.8\ZZZ.Framework.Monogame.dll

#---------------------------------- Content ---------------------------------#

#begin Sprites/main.png
/importer:TextureImporter
/processor:SpriteProcessor
/processorParam:FrameWidth=32
/processorParam:FrameHeight=32
/processorParam:OffsetStartX=0
/processorParam:OffsetStartY=0
/processorParam:OffsetEndX=0
/processorParam:OffsetEndY=0
/processorParam:OriginX=16
/processorParam:OriginY=16
/build:Sprites/main.png

